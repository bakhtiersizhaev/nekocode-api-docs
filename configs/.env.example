# Nekocode API Configuration
# Copy to .env and fill in your API key

# Your Nekocode API key (get from https://nekocode.app/dashboard/api-keys)
NEKOCODE_API_KEY=sk_live_your_api_key

# Gateway (choose one)
# Default (Global): https://gateway.nekocode.app
# Russia:           https://ru.gateway.nekocode.app
# Russia #2:        https://ru-2.gateway.nekocode.app
# Russia #3:        https://ru-3.gateway.nekocode.app
NEKOCODE_GATEWAY=https://gateway.nekocode.app

# Channel (choose one)
# Alpha (x0.3 price): /alpha
# Spark (x1, 1M ctx): /spark
NEKOCODE_CHANNEL=alpha

# Computed base URLs (do not edit manually)
ANTHROPIC_BASE_URL=${NEKOCODE_GATEWAY}/${NEKOCODE_CHANNEL}
ANTHROPIC_AUTH_TOKEN=${NEKOCODE_API_KEY}
OPENAI_BASE_URL=${NEKOCODE_GATEWAY}/${NEKOCODE_CHANNEL}/v1
OPENAI_API_KEY=${NEKOCODE_API_KEY}
