# Default environment (no Nekocode proxy)
# Source this to revert: source .env.default
unset ANTHROPIC_BASE_URL
unset ANTHROPIC_AUTH_TOKEN
unset OPENAI_BASE_URL
unset NEKOCODE_API_KEY
unset NEKOCODE_GATEWAY
unset NEKOCODE_CHANNEL
unset ANTHROPIC_API_BASE
unset NEKOCODE_API_KEY
# Your tools will now use their default API endpoints
